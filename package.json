{
  "name": "home-design-system",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "Dark-only, information-first shared design system for the home platform — tokens + router-agnostic React components + AgentChat + widgets.",
  "sideEffects": ["*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens/design-tokens.css",
    "./theme.css": "./src/tokens/theme.css",
    "./icon.svg": "./src/icon.svg"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src/tokens", "src/icon.svg"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "check:accents": "node --experimental-strip-types scripts/check-accents.ts",
    "gen:accents": "node --experimental-strip-types scripts/check-accents.ts --css",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "peerDependenciesMeta": {
    "react": { "optional": false },
    "react-dom": { "optional": false }
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "^8.3.5",
    "typescript": "^5"
  }
}
